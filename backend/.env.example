# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/propanalyzer

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-secret-key-here-change-in-production

# Environment
ENVIRONMENT=development

# External APIs (Optional)
ZILLOW_API_KEY=
RENTCAST_API_KEY=
ATTOM_API_KEY=
GOOGLE_MAPS_API_KEY=

# Stripe (Optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AWS (Optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# Email (Optional)
SENDGRID_API_KEY=
FROM_EMAIL=noreply@propanalyzer.com
